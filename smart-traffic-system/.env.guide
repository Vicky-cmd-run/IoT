# Copy this file to `.env` and fill in the values you choose.
# For most fields below, you can leave the defaults during the first local setup.

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
APP_ENV=development
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Database
# If you use the provided Docker setup, you can keep these values as-is or
# replace only the password with your own strong password.
# -----------------------------------------------------------------------------
POSTGRES_DB=smart_traffic
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql://postgres:change_me@db:5432/smart_traffic

# -----------------------------------------------------------------------------
# SUMO / TraCI
# On macOS with Homebrew, first run:
#   brew install sumo
# Then check:
#   which sumo
#   brew --prefix sumo
# If you are not wiring live SUMO yet, keep TRACI_ENABLED=false for now.
# -----------------------------------------------------------------------------
SUMO_HOME=/Users/your-user/path/to/sumo
SUMO_BINARY=/Users/your-user/path/to/sumo/bin/sumo
TRACI_ENABLED=true
SUMO_CONFIG=../simulation/config.sumocfg

# -----------------------------------------------------------------------------
# Map provider
# Choose one provider:
#   osm      -> no API key needed
#   mapbox   -> requires MAPBOX_API_KEY
#   tomtom   -> requires TOMTOM_API_KEY
#   google   -> requires GOOGLE_MAPS_API_KEY
# -----------------------------------------------------------------------------
MAP_PROVIDER=osm
MAPBOX_API_KEY=
TOMTOM_API_KEY=
GOOGLE_MAPS_API_KEY=

# -----------------------------------------------------------------------------
# Weather
# Optional. Get from https://openweathermap.org/api
# -----------------------------------------------------------------------------
OPENWEATHER_API_KEY=

# -----------------------------------------------------------------------------
# Streaming
# Optional. Only fill these if you want live broker/queue integration.
# -----------------------------------------------------------------------------
MQTT_BROKER_URL=
MQTT_USERNAME=
MQTT_PASSWORD=
KAFKA_BOOTSTRAP_SERVERS=

# -----------------------------------------------------------------------------
# Cache
# Safe default for local Docker setup.
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# Auth
# Generate a JWT secret with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
# For the first version, simple admin login is enough.
# -----------------------------------------------------------------------------
JWT_SECRET=
JWT_ALGORITHM=HS256
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_too
