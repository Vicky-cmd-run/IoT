# ── App ─────────────────────────────────────────────────────
APP_ENV=production
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ── Auth ────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace_with_64_char_hex_secret
JWT_ALGORITHM=HS256
ADMIN_EMAIL=your@email.com
ADMIN_PASSWORD=YourStrongPassword123

# ── Demo mode (no SUMO required) ───────────────────────────
# Set false for Railway demo deployment (uses DemoSimulationEngine)
# Set true only if you have SUMO installed on the server
TRACI_ENABLED=false
SUMO_BINARY=sumo
SUMO_CONFIG=../simulation/config.sumocfg

# ── Map ─────────────────────────────────────────────────────
MAP_PROVIDER=osm

# ── Weather (optional) ──────────────────────────────────────
# Get free key at https://openweathermap.org/api
OPENWEATHER_API_KEY=

# ── Database (optional — not required for demo mode) ────────
DATABASE_URL=postgresql://postgres:password@db:5432/smart_traffic

# ── Frontend env (set in Vercel dashboard) ──────────────────
# VITE_API_BASE_URL=https://your-railway-backend-url.up.railway.app
